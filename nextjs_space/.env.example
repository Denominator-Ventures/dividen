# DiviDen Command Center - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Use your own local or hosted Postgres instance.
# Example: postgresql://user:password@localhost:5432/dividen
DATABASE_URL=postgresql://user:password@localhost:5432/dividen

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Admin password for the /admin dashboard
ADMIN_PASSWORD=your-admin-password

# ─── AI / LLM (Optional) ────────────────────────────────────────────────────
# Leave blank to run without AI features.
# Users can also add their own API keys in Settings → API Keys.
ABACUSAI_API_KEY=

# ─── Notifications (Optional) ────────────────────────────────────────────────
# Only needed if you want to send invitation emails.
# WEB_APP_ID=
# NOTIF_ID_CONNECTION_INVITATION=
