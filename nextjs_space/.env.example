# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  DiviDen Command Center — Environment Configuration                         ║
# ║  Copy this file to .env and fill in your values:                            ║
# ║    cp .env.example .env                                                     ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Option A: Use the included docker-compose (easiest):
#   docker compose up -d
#   Then use the URL below as-is.
# Option B: Use any hosted Postgres (Neon, Supabase, Railway, etc.)
#   Replace with your connection string.
DATABASE_URL=postgresql://dividen:dividen@localhost:5432/dividen

# Session encryption key. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET

# Password for the /admin dashboard.
ADMIN_PASSWORD=admin

# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# AI / LLM — Leave blank to run without AI features.
# Users can also add their own OpenAI or Anthropic keys in Settings → API Keys.
ABACUSAI_API_KEY=

# Notification emails — Only needed for invitation emails.
# WEB_APP_ID=
# NOTIF_ID_CONNECTION_INVITATION=

# ─── PAYMENTS (Stripe) ──────────────────────────────────────────────────────
# Required only for marketplace payments and job recruiting fees.
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   (optional, for webhook signature verification)

# ─── FEES ────────────────────────────────────────────────────────────────────
# Platform fees — set to 0 for self-hosted / community instances.
# MARKETPLACE_FEE_PERCENT=3        (default: 3% marketplace routing fee)
# RECRUITING_FEE_PERCENT=7         (default: 7% recruiting fee)
