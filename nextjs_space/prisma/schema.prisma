// DiviDen Command Center - Database Schema
// Supports PostgreSQL

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/dividen_command_center/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Authentication & Users ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          String    @default("admin")
  mode          String    @default("cockpit") // "cockpit" | "chief_of_staff"
  hasSeenWalkthrough    Boolean @default(false)
  hasCompletedOnboarding Boolean @default(false)
  acceptedTermsAt       DateTime? // null = not yet accepted
  termsVersion          String?   // e.g. "1.0" — which version they accepted
  notificationsLastSeen DateTime? // Timestamp of last notification feed view

  // Stripe integration
  stripeCustomerId        String?   @unique // Stripe customer ID for payment methods
  stripeConnectAccountId  String?   @unique // Stripe Connect Express account ID for payouts
  stripeConnectOnboarded  Boolean   @default(false) // Has completed Stripe Connect onboarding

  // Free tier
  isFreeUser    Boolean   @default(false) // Bypasses billing checks when true

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  kanbanCards   KanbanCard[]
  chatMessages  ChatMessage[]
  contacts      Contact[]
  memoryItems   MemoryItem[]
  userLearnings UserLearning[]
  agentApiKeys  AgentApiKey[]
  agentCapabilities AgentCapability[]
  externalApiKeys ExternalApiKey[]
  webhooks      Webhook[]
  serviceApiKeys ServiceApiKey[]
  documents     Document[]
  recordings      Recording[]
  commsMessages   CommsMessage[]
  calendarEvents  CalendarEvent[]
  emailMessages   EmailMessage[]
  integrationAccounts IntegrationAccount[]
  notificationRules   NotificationRule[]
  connectionsRequested Connection[] @relation("ConnectionsRequested")
  connectionsAccepted  Connection[] @relation("ConnectionsAccepted")
  relaysSent           AgentRelay[] @relation("RelaysSent")
  relaysReceived       AgentRelay[] @relation("RelaysReceived")
  jobsPosted           NetworkJob[] @relation("JobsPosted")
  jobsAssigned         NetworkJob[] @relation("JobsAssigned")
  jobApplications      JobApplication[] @relation("JobApplications")
  jobContractsAsClient JobContract[] @relation("JobContractsAsClient")
  jobContractsAsWorker JobContract[] @relation("JobContractsAsWorker")
  reputationScores     ReputationScore[] @relation("ReputationScores")
  profile              UserProfile?
  invitations          Invitation[]
  projectInvitesSent     ProjectInvite[] @relation("ProjectInvitesSent")
  projectInvitesReceived ProjectInvite[] @relation("ProjectInvitesReceived")
  teamsCreated         Team[]          @relation("TeamsCreated")
  teamMemberships      TeamMember[]
  projectsCreated      Project[]       @relation("ProjectsCreated")
  projectMemberships   ProjectMember[]
  goals                Goal[]
  agentExtensions      AgentExtension[]
  marketplaceAgents    MarketplaceAgent[]   @relation("MarketplaceAgentsListed")
  marketplaceSubs      MarketplaceSubscription[] @relation("MarketplaceSubscriptions")
  marketplaceExecs     MarketplaceExecution[]   @relation("MarketplaceExecutions")
  contactPlatformLinks Contact[]                @relation("ContactPlatformLinks")
  teamFollows          TeamFollow[]
  teamAgentGrants      TeamAgentAccess[]        @relation("TeamAgentGrantedBy")
  signalConfigs        SignalConfig[]
  customSignals        CustomSignal[]

  // Profile
  profilePhotoUrl   String?   // Public S3 URL for profile photo

  // Divi personalization
  diviName          String?   // Custom name for their agent (default "Divi")
  workingStyle      Json?     // { verbosity: 1-5, proactivity: 1-5, autonomy: 1-5, formality: 1-5 }
  triageSettings    Json?     // { autoMerge: bool, autoRouteToBoard: bool, triageStyle: string, dueDateDefaults: json }
  goalsEnabled      Boolean   @default(false) // Whether Goals section is active

  @@map("users")
}

// ─── Kanban Board ──────────────────────────────────────────────────────────────

model KanbanCard {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      String          @default("leads") // pipeline stage
  priority    String          @default("medium")   // "low" | "medium" | "high" | "urgent"
  assignee    String          @default("human") // "human" | "agent"
  dueDate     DateTime?
  order       Int             @default(0)
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  projectId   String?

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  checklist      ChecklistItem[]
  contacts       CardContact[]
  documents      Document[]
  recordings     Recording[]
  calendarEvents CalendarEvent[]
  commsMessages  CommsMessage[]
  emailMessages  EmailMessage[]
  artifacts      CardArtifact[]    // Generic artifacts from any signal type

  @@index([projectId])
  @@map("kanban_cards")
}

model ChecklistItem {
  id          String     @id @default(cuid())
  text        String
  completed   Boolean    @default(false)
  order       Int        @default(0)
  cardId      String
  dueDate     DateTime?  // When this task should be completed by

  // ── Source traceability ──
  sourceType  String?    // Signal type that generated this task (e.g., "email", "calendar", "slack_webhook")
  sourceId    String?    // ID of the source artifact (email ID, event ID, etc.)
  sourceLabel String?    // Human-readable origin (e.g., "Email from John", "Meeting: Standup")

  // ── Task assignment & delegation ──
  assigneeType  String   @default("self")  // "self" = operator, "divi" = Divi direct, "delegated" = another user's Divi
  assigneeName  String?  // Display name: null for self, "Divi" for divi, "Sarah Chen via Divi" for delegated
  assigneeId    String?  // For delegated: the Connection.id or Contact.platformUserId of the person responsible
  delegationStatus String? // For delegated tasks: "pending" | "sent" | "accepted" | "in_progress" | "completed" | "declined"

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  card        KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// Generic artifact linking — extensible for any signal type (custom webhooks, integrations, etc.)
model CardArtifact {
  id           String     @id @default(cuid())
  cardId       String
  artifactType String     // "email", "document", "recording", "calendar_event", "contact", "comms", or any custom type
  artifactId   String     // ID of the linked artifact
  label        String?    // Human-readable label (e.g., "Email: Re: Q4 budget")
  metadata     String?    // JSON — extra context from the signal source
  createdAt    DateTime   @default(now())

  card         KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, artifactType, artifactId]) // No duplicate links
  @@index([artifactType, artifactId])
  @@map("card_artifacts")
}

// ─── Queue System ──────────────────────────────────────────────────────────────

model QueueItem {
  id          String   @id @default(cuid())
  type        String   // "task" | "notification" | "reminder" | "agent_suggestion"
  title       String
  description String?
  priority    String   @default("medium")  // "low" | "medium" | "high" | "urgent"
  status      String   @default("ready")   // "ready" | "in_progress" | "done_today" | "blocked"
  source      String?  // "user" | "agent" | "system"
  userId      String?
  projectId   String?
  teamId      String?
  metadata    String?  // JSON string for flexible data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([teamId])
  @@index([userId, status])   // Composite: user queue by status
  @@index([status, createdAt]) // Composite: overdue task checks
  @@map("queue_items")
}

// ─── Chat & Agent Communication ────────────────────────────────────────────────

model ChatMessage {
  id        String    @id @default(cuid())
  role      String    // "user" | "assistant" | "system"
  content   String
  userId    String?
  metadata  String?   // JSON string
  clearedAt DateTime? // when set, message is hidden from UI but still exists in DB
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, clearedAt])
  @@map("chat_messages")
}

model AgentMessage {
  id        String   @id @default(cuid())
  agentName String
  type      String   // "status_update" | "suggestion" | "alert" | "completion"
  content   String
  priority  String   @default("normal")
  read      Boolean  @default(false)
  metadata  String?  // JSON string
  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("agent_messages")
}

// ─── CRM / Contacts ───────────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  role         String?
  notes        String?
  tags         String?       // Comma-separated tags
  source       String?       // "manual" | "chat" | "enriched"
  enrichedData String?       // JSON string for enrichment data
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // ── Platform User Bridge ──
  platformUserId     String?   // Links to User.id if this contact is on DiviDen
  platformUserStatus String?   // "matched" | "invited" | "confirmed"
  matchedAt          DateTime? // When the link was established

  platformUser  User?         @relation("ContactPlatformLinks", fields: [platformUserId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards             CardContact[]
  commsMessages     CommsMessage[]
  emailMessages     EmailMessage[]
  relationshipsFrom ContactRelationship[] @relation("RelFrom")
  relationshipsTo   ContactRelationship[] @relation("RelTo")

  @@index([platformUserId])
  @@index([email])
  @@map("contacts")
}

model ContactRelationship {
  id           String   @id @default(cuid())
  fromId       String
  toId         String
  type         String   // "colleague" | "manager" | "report" | "partner" | "spouse" | "friend" | "referral" | "custom"
  label        String?  // Optional freeform label (e.g. "introduced by")
  createdAt    DateTime @default(now())

  from         Contact  @relation("RelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to           Contact  @relation("RelTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
  @@map("contact_relationships")
}

model CardContact {
  id            String     @id @default(cuid())
  cardId        String
  contactId     String
  role          String?    // Contact's contextual role (e.g., "CTO", "Project Lead", "Investor")
  involvement   String     @default("related") // "contributor" = can take/is taking tasks | "related" = contextual only
  canDelegate   Boolean    @default(false)      // true if this person is a DiviDen user (has platformUserId on Contact)
  createdAt     DateTime   @default(now())

  card          KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  contact       Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([cardId, contactId])
  @@map("card_contacts")
}

// ─── AI Memory & Learning ──────────────────────────────────────────────────────

model MemoryItem {
  id         String   @id @default(cuid())
  tier       Int      @default(1) // 1=Explicit Facts, 2=Behavioral Rules, 3=Learned Patterns
  category   String   // Tier1: "general"|"project"|"contact" | Tier2: "communication"|"workflow"|"preferences" | Tier3: "style"|"preference"|"workflow"|"communication"
  key        String
  value      String
  scope      String?  // Tier1: scope context (e.g., project name, contact name)
  pinned     Boolean  @default(false) // Tier1: pin for high priority
  priority   String?  // Tier2: "critical"|"high"|"medium"|"low"
  confidence Float?   // Tier3: confidence score 0.0-1.0
  approved   Boolean? // Tier3: user approval status (null=pending, true=approved, false=rejected)
  source     String?  // "user" | "agent" | "system"
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("memory_items")
}

model AgentRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  rule        String   // The actual rule text
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("agent_rules")
}

// ─── Agent Capabilities ─────────────────────────────────────────────────────────
// Outbound actions Divi can perform on behalf of the user.
// Each capability has a type, status (enabled/disabled/setup), and user-defined rules.

model AgentCapability {
  id          String   @id @default(cuid())
  type        String   // "email" | "meetings" | "custom"
  name        String   // Display name, e.g. "Outbound Email" or "Meeting Scheduling"
  status      String   @default("setup") // "setup" | "enabled" | "disabled" | "paused"
  identity    String   @default("operator") // "operator" (send as user) | "agent" (send as Divi) | "both"
  rules       String?  // JSON array of rules — e.g. [{ "rule": "Always CC me on emails to clients", "enabled": true }]
  config      String?  // JSON — capability-specific config (e.g. signature, tone, scheduling prefs)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("agent_capabilities")
}

// ─── Signal Configuration ───────────────────────────────────────────────────

model SignalConfig {
  id              String   @id @default(cuid())
  signalId        String   // Matches SignalDefinition.id or CustomSignal.id
  priority        Int      @default(50) // Lower = higher priority (1-100)
  catchUpEnabled  Boolean  @default(true) // Include in catch-up triage
  triageEnabled   Boolean  @default(true) // Show triage button
  triagePrompt    String?  // User-customized triage prompt (null = use smart default)
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, signalId])
  @@index([userId])
  @@map("signal_configs")
}

model CustomSignal {
  id                  String   @id @default(cuid())
  signalId            String   // Unique identifier for this signal (slug)
  name                String   // Display name
  icon                String   @default("🔔") // Emoji icon
  description         String   // What this signal is
  inboundDescription  String   // What data comes in
  triagePrompt        String   // Prompt for triaging this signal
  cardTypes           String   // JSON array of card type strings
  category            String   @default("data") // communication | meetings | content | data
  webhookUrl          String?  // If connected via webhook, the URL to receive events
  webhookSecret       String?  // Secret for webhook verification
  integrationId       String?  // Link to IntegrationAccount if applicable
  isActive            Boolean  @default(true)
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, signalId])
  @@index([userId])
  @@map("custom_signals")
}

model UserLearning {
  id          String   @id @default(cuid())
  category    String   // "style" | "preference" | "workflow" | "communication"
  observation String
  confidence  Float    @default(0.5)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_learnings")
}

// ─── Configuration ─────────────────────────────────────────────────────────────

model AgentApiKey {
  id        String   @id @default(cuid())
  provider  String   // "openai" | "anthropic"
  label     String?
  apiKey    String   // Encrypted in production
  isActive  Boolean  @default(true)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("agent_api_keys")
}

// ─── Webhook Infrastructure ──────────────────────────────────────────────────

model Webhook {
  id          String       @id @default(cuid())
  name        String
  type        String       // "calendar" | "email" | "transcript" | "generic"
  url         String?      // Generated webhook URL path
  secret      String       // Secret for signature validation
  isActive    Boolean      @default(true)
  mappingRules String?     // JSON string for payload-to-action mapping rules
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        WebhookLog[]

  @@index([userId])
  @@index([secret])
  @@map("webhooks")
}

model WebhookLog {
  id          String   @id @default(cuid())
  webhookId   String
  payload     String   // JSON string of incoming payload
  status      String   // "success" | "error" | "ignored"
  statusCode  Int      @default(200)
  error       String?
  actionsRun  String?  // JSON string of actions executed
  createdAt   DateTime @default(now())

  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_logs")
}

model ServiceApiKey {
  id          String   @id @default(cuid())
  service     String   // "sendgrid" | "twilio" | "slack" | "custom" etc.
  keyName     String   // Display name / label
  keyValue    String   // Encrypted API key value
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("service_api_keys")
}

// ─── Documents / Drive ──────────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  title       String
  content     String?  // Markdown content
  type        String   @default("note") // "note" | "report" | "template" | "meeting_notes"
  tags        String?  // Comma-separated
  url         String?  // External file URL (Google Drive, Dropbox, etc.)
  fileSource  String   @default("local") // "local" | "google_drive" | "dropbox" | "onedrive" | "url"
  cardId      String?  // Optional link to a KanbanCard
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        KanbanCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  commsMessages CommsMessage[]

  @@index([userId])
  @@map("documents")
}

// ─── Recordings (Plaud, Otter, Fireflies, etc.) ────────────────────────────

model Recording {
  id          String   @id @default(cuid())
  title       String
  source      String   @default("generic") // "plaud" | "otter" | "fireflies" | "generic"
  transcript  String?  // Full transcript text
  summary     String?  // AI-generated summary
  duration    Int?     // Duration in seconds
  status      String   @default("pending") // "pending" | "processed" | "reviewed"
  metadata    String?  // JSON string for flexible data
  cardId      String?  // Optional link to a KanbanCard
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        KanbanCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  commsMessages CommsMessage[]

  @@index([userId])
  @@map("recordings")
}

// ─── Activity Log ───────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // "card_created" | "card_moved" | "task_dispatched" | "contact_added" | "mode_changed" | "recording_processed" etc.
  actor     String   @default("user") // "user" | "divi" | "system" | agent name
  summary   String   // Human-readable description
  metadata  String?  // JSON string with details
  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt]) // Composite: notification feed, activity timeline
  @@index([userId, action])    // Composite: category-filtered activity queries
  @@map("activity_logs")
}

// ─── Calendar Events ─────────────────────────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  location    String?
  attendees   String?   // JSON array of attendees
  source      String    @default("webhook") // "webhook" | "manual" | "google"
  externalId  String?   // ID from external system
  metadata    String?   // JSON string
  cardId      String?   // Optional link to a KanbanCard
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        KanbanCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([startTime])
  @@index([userId, startTime]) // Composite: user calendar range queries
  @@map("calendar_events")
}

// ─── Email Messages ──────────────────────────────────────────────────────────

model EmailMessage {
  id              String     @id @default(cuid())
  subject         String
  fromName        String?
  fromEmail       String?
  toEmail         String?
  body            String?    // Full body or preview
  snippet         String?    // Short preview
  labels          String?    // Comma-separated: "inbox,important,starred"
  isRead          Boolean    @default(false)
  isStarred       Boolean    @default(false)
  source          String     @default("webhook") // "webhook" | "manual" | "gmail"
  externalId      String?    // ID from external system
  linkedCardId    String?
  linkedContactId String?
  metadata        String?    // JSON string
  userId          String
  receivedAt      DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedCard      KanbanCard? @relation(fields: [linkedCardId], references: [id], onDelete: SetNull)
  linkedContact   Contact?   @relation(fields: [linkedContactId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([receivedAt])
  @@index([isRead])
  @@index([userId, isRead, receivedAt]) // Composite: unread email queries
  @@map("email_messages")
}

// ─── Comms Channel ───────────────────────────────────────────────────────────

model CommsMessage {
  id              String     @id @default(cuid())
  sender          String     // "user" | "divi" | "system"
  content         String
  state           String     @default("new") // "new" | "read" | "acknowledged" | "resolved" | "dismissed"
  priority        String     @default("normal") // "urgent" | "normal" | "low"
  linkedCardId    String?
  linkedContactId String?
  linkedRecordingId String?
  linkedDocumentId String?
  metadata        String?    // JSON string for flexible data
  userId          String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedCard      KanbanCard? @relation(fields: [linkedCardId], references: [id], onDelete: SetNull)
  linkedContact   Contact?   @relation(fields: [linkedContactId], references: [id], onDelete: SetNull)
  linkedRecording Recording? @relation(fields: [linkedRecordingId], references: [id], onDelete: SetNull)
  linkedDocument  Document?  @relation(fields: [linkedDocumentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([state])
  @@index([createdAt])
  @@map("comms_messages")
}

// External Agent API Keys for v2 API authentication
model ExternalApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  keyPrefix   String
  permissions String    @default("all")
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
  @@map("external_api_keys")
}

// ─── Integration Accounts (Dual Identity) ──────────────────────────────────────
// Each user can have integration credentials for both their own identity
// ("operator") and their agent's identity ("agent"). This enables the agent
// to operate with its own email, calendar, and drive — separate from the user's.

model IntegrationAccount {
  id            String   @id @default(cuid())
  userId        String
  identity      String   // "operator" | "agent"
  provider      String   // "google" | "microsoft" | "smtp"
  service       String   // "email" | "calendar" | "drive"
  label         String?  // Display name, e.g. "Divi's Gmail" or "My Work Calendar"

  // OAuth fields
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?
  scope         String?

  // SMTP / App Password fields
  smtpHost      String?
  smtpPort      Int?
  smtpUser      String?
  smtpPass      String?  // encrypted at rest

  // Shared config
  emailAddress  String?  // The actual email address for this identity
  isActive      Boolean  @default(true)
  lastSyncAt    DateTime?
  syncCursor    String?  // Pagination cursor for incremental sync
  metadata      String?  // JSON - provider-specific config

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, identity, service])
  @@index([userId])
  @@map("integration_accounts")
}

// ─── Notification Rules ────────────────────────────────────────────────────────
// User-defined rules that trigger cockpit banners when conditions are met.

model NotificationRule {
  id          String   @id @default(cuid())
  userId      String
  name        String   // e.g. "Meeting Starting Soon"
  eventType   String   // "meeting_starting" | "task_overdue" | "email_received" | "contact_stale" | "card_moved" | "queue_added" | "custom"
  conditions  String?  // JSON — optional extra conditions (e.g. {"minutesBefore": 5})
  message     String   // Template string, e.g. "Meeting '{{title}}' starts in {{minutes}}m"
  style       String   @default("info") // "info" | "warning" | "urgent" | "success"
  sound       Boolean  @default(false)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_rules")
}

// ─── Connections ──────────────────────────────────────────────────────────────
// Links between two users, enabling agent-to-agent communication.
// Connections can be local (same instance) or federated (cross-instance).

model Connection {
  id              String   @id @default(cuid())
  requesterId     String   // User who initiated the connection
  accepterId      String?  // User who accepted (null if federated pending)
  status          String   @default("pending") // "pending" | "active" | "blocked" | "declined"

  // Permission scopes — what the other party's agent can do
  permissions     String   @default("{\"trustLevel\":\"supervised\",\"scopes\":[]}") // JSON: { trustLevel, scopes[] }

  // Display
  nickname        String?  // How the requester refers to the other party
  peerNickname    String?  // How the accepter refers to the requester

  // ── Relationship Context ──
  notes            String?   @db.Text  // "Met at Web Summit 2025" — private to each side
  connectionTags   String?   // JSON array: ["investor", "ai", "NYC"]
  context          String?   // "How I know them" freeform
  relationshipType String?   // "colleague" | "client" | "friend" | "mentor" | "collaborator" | "partner"
  firstMetAt       DateTime? // When did you first meet?
  strength         String?   // "strong" | "moderate" | "weak" — manual or auto-decayed

  // Federation fields (cross-instance connections)
  isFederated     Boolean  @default(false)
  peerInstanceUrl String?  // The remote instance's base URL
  peerUserId      String?  // The user ID on the remote instance
  peerUserName    String?  // Display name of the remote user
  peerUserEmail   String?  // Email of the remote user
  federationToken String?  // Shared secret for authenticating relay messages

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester       User     @relation("ConnectionsRequested", fields: [requesterId], references: [id], onDelete: Cascade)
  accepter        User?    @relation("ConnectionsAccepted", fields: [accepterId], references: [id], onDelete: Cascade)
  relays          AgentRelay[]
  teamMemberships TeamMember[]
  projectMemberships ProjectMember[]
  projectInvites  ProjectInvite[]

  @@unique([requesterId, accepterId])
  @@index([requesterId])
  @@index([accepterId])
  @@index([status])
  @@map("connections")
}

// ─── Agent Relay ──────────────────────────────────────────────────────────────
// Structured request/response protocol between connected agents.
// This is the core communication primitive — Divi-to-Divi messaging.

model AgentRelay {
  id              String    @id @default(cuid())
  connectionId    String
  fromUserId      String    // Sender (local user ID)
  toUserId        String?   // Receiver (local user ID, null if federated)
  direction       String    @default("outbound") // "outbound" | "inbound"

  // Message classification
  type            String    // "request" | "response" | "notification" | "update"
  intent          String    // "get_info" | "assign_task" | "request_approval" | "share_update" | "schedule" | "introduce" | "custom"
  subject         String
  payload         String?   // JSON — structured data for the relay
  
  // Lifecycle
  status          String    @default("pending") // "pending" | "delivered" | "agent_handling" | "user_review" | "completed" | "declined" | "expired"
  priority        String    @default("normal") // "urgent" | "normal" | "low"
  dueDate         DateTime?
  resolvedAt      DateTime?
  responsePayload String?   // JSON — the response data

  // Threading (FVP Brief Proposal #2)
  threadId        String?   // Groups all relays in a multi-turn conversation thread
  parentRelayId   String?
  parentRelay     AgentRelay?  @relation("RelayThread", fields: [parentRelayId], references: [id], onDelete: SetNull)
  childRelays     AgentRelay[] @relation("RelayThread")

  // Structured Artifacts (FVP Brief Proposal #3)
  artifactType    String?   // "text" | "code" | "document" | "data" | "contact_card" | "calendar_invite" | "email_draft"
  artifacts       String?   // JSON array of typed artifact objects

  // Federation
  peerRelayId     String?   // The relay ID on the remote instance
  peerInstanceUrl String?   // Remote instance URL (for federated relays)

  // Queue bridge (DEP-003)
  queueItemId     String?   @unique // Links relay to a local queue item (1:1)

  // Team/Project context
  teamId          String?
  projectId       String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  connection      Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  fromUser        User       @relation("RelaysSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User?      @relation("RelaysReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  team            Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  project         Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([connectionId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@index([createdAt])
  @@index([threadId])
  @@index([fromUserId, status, createdAt]) // Composite: user relay inbox/outbox
  @@index([toUserId, status])              // Composite: inbound relay filtering
  @@map("agent_relays")
}

// ─── Ambient Relay Learning System ─────────────────────────────────────────────
// Captures outcome signals from every ambient relay to learn what works.
// Cross-user patterns are synthesized into AmbientPatterns that feed back
// into the system prompt, making ambient communication progressively better.

model AmbientRelaySignal {
  id                String    @id @default(cuid())
  relayId           String    // The AgentRelay this signal is about
  fromUserId        String    // Who sent the ambient relay
  toUserId          String?   // Who received it

  // ── Timing Metrics ──
  relayCreatedAt    DateTime  // When the ambient relay was created
  wovenAt           DateTime? // When Divi actually wove the question into conversation (relay_respond timestamp)
  respondedAt       DateTime? // When the response was sent back
  latencyMinutes    Int?      // Minutes from relay creation to weaving
  responseMinutes   Int?      // Minutes from weaving to response

  // ── Outcome Signals ──
  outcome           String    // "answered" | "declined" | "ignored" | "deferred"
  responseQuality   String?   // "substantive" | "brief" | "dismissive" | null (agent-assessed)
  disruptionLevel   String?   // "seamless" | "noticed" | "disruptive" | null (agent-assessed)
  topicRelevance    String?   // "on_topic" | "adjacent" | "forced" | null

  // ── Context ──
  ambientTopic      String?   // The topic tag from the relay payload
  conversationTopic String?   // What was being discussed when the question was woven in
  questionPhrasing  String?   // How Divi phrased the question
  dayOfWeek         Int?      // 0=Sun, 6=Sat
  hourOfDay         Int?      // 0-23 in recipient's timezone

  // ── Feedback ──
  userFeedback      String?   // "helpful" | "unnecessary" | "bad_timing" | null (explicit user feedback)
  metadata          String?   // JSON — additional context (intent, priority, detection info)

  createdAt         DateTime  @default(now())

  @@index([fromUserId])
  @@index([toUserId])
  @@index([relayId])
  @@index([outcome])
  @@index([createdAt])
  @@map("ambient_relay_signals")
}

model AmbientPattern {
  id              String    @id @default(cuid())
  patternType     String    // "timing" | "topic" | "phrasing" | "frequency" | "routing" | "general"
  description     String    // Human-readable pattern description
  insight         String    // The actionable learning for Divi
  confidence      Float     @default(0.5)  // 0.0-1.0, increases with more confirming signals
  signalCount     Int       @default(0)    // How many signals contributed to this pattern
  scope           String    @default("global") // "global" | "user:{userId}" — who does this apply to

  // ── Pattern Data ──
  metadata        String?   // JSON — supporting data (e.g., best hours, topic correlations)

  // ── Lifecycle ──
  isActive        Boolean   @default(true)
  lastSynthesized DateTime  @default(now()) // When this pattern was last updated
  expiresAt       DateTime? // Optional — some patterns may decay

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([patternType])
  @@index([scope])
  @@index([isActive])
  @@map("ambient_patterns")
}

// ─── Agent Briefs (Reasoning Receipts / Provenance Layer) ─────────────────────
// Every time Divi decomposes a task, routes a relay, or takes an orchestrated action,
// it generates a brief — the assembled context snapshot that shows WHY the action was taken.
// This is the "show your work" layer. Humans can inspect any agent action to verify reasoning.

model AgentBrief {
  id              String    @id @default(cuid())
  userId          String    // The user whose Divi generated this brief
  type            String    // "task_decomposition" | "relay_routing" | "ambient_ask" | "broadcast" | "skill_match" | "orchestration"
  title           String    // Human-readable summary: "Routed financial review to Marcus"

  // ── Source Context ──
  sourceCardId    String?   // The Kanban card that triggered this brief
  sourceContactIds String?  // JSON array of contact IDs involved
  sourceRelayId   String?   // If this brief was generated for/from a relay

  // ── Assembled Brief (the .md) ──
  briefMarkdown   String    // The full assembled context as Markdown
  promptUsed      String?   // The constructed prompt/instruction sent to the agent or relay

  // ── Routing Decision ──
  matchedUserId   String?   // Who was selected as the target (for skill-matching)
  matchReasoning  String?   // Why this person/agent was chosen
  matchedSkills   String?   // JSON array of matched skills/taskTypes
  routeType       String?   // "direct" | "broadcast" | "ambient" | "self" — how the task was routed

  // ── Outcome ──
  resultRelayId   String?   // The relay that was created from this brief
  resultAction    String?   // What action was taken: "relay_sent" | "task_created" | "suggestion_made"
  status          String    @default("assembled") // "assembled" | "routed" | "completed" | "cancelled"

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([sourceCardId])
  @@index([sourceRelayId])
  @@index([resultRelayId])
  @@index([createdAt])
  @@map("agent_briefs")
}

// ─── Instance Registry ────────────────────────────────────────────────────────
// Tracks known DiviDen instances for federation.
// Each instance has a shared API key for authenticating relay messages.

model InstanceRegistry {
  id              String   @id @default(cuid())
  name            String   // Display name, e.g. "Acme Corp DiviDen"
  baseUrl         String   @unique // The instance's public URL
  apiKey          String   // Shared secret for authenticating inbound relays
  isActive        Boolean  @default(true)
  isTrusted       Boolean  @default(false) // Admin-approved trust
  lastSeenAt      DateTime?
  metadata        String?  // JSON — capabilities, version, etc.

  // ── Platform Link (self-hosted → managed network) ──
  platformLinked      Boolean  @default(false) // Has completed Connect to Network registration
  platformToken       String?  // Token issued by managed platform for API access
  marketplaceEnabled  Boolean  @default(false) // Can list agents on managed marketplace
  discoveryEnabled    Boolean  @default(false) // Can query managed network discovery feed
  updatesEnabled      Boolean  @default(false) // Pulls changelog from managed platform
  version             String?  // Self-reported instance version, e.g. "2.1.0"
  userCount           Int?     // Self-reported user count for network stats
  agentCount          Int?     // Self-reported marketplace agent count
  lastSyncAt          DateTime? // Last successful sync with managed platform

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([baseUrl])
  @@map("instance_registry")
}

// ─── User Profile ─────────────────────────────────────────────────────────────
// Extended identity — professional + lived experience + availability.
// Shared with connections so agents can assess fitness for tasks.

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  
  // ── Professional ──
  headline        String?  // "Founder & CEO at Acme" — one-liner
  bio             String?  // Longer narrative bio
  currentTitle    String?
  currentCompany  String?
  industry        String?
  skills          String?  // JSON array: ["negotiation","python","design"]
  experience      String?  // JSON array: [{title,company,startYear,endYear,description}]
  education       String?  // JSON array: [{school,degree,field,year}]
  linkedinUrl     String?
  linkedinData    String?  // JSON — raw imported LinkedIn data

  // ── Lived Experience ──
  languages       String?  // JSON array: [{language,proficiency}] — "native","fluent","conversational","basic"
  countriesLived  String?  // JSON array: [{country,years,context}]
  lifeExperiences String?  // JSON array: [{category,description,year?}] — freeform life milestones
  volunteering    String?  // JSON array: [{org,role,description}]
  hobbies         String?  // JSON array: ["photography","hiking","chess"]
  personalValues  String?  // JSON array: ["integrity","creativity","empathy"]
  superpowers     String?  // JSON array — self-identified strengths beyond skills: ["crisis management","cross-cultural communication"]
  taskTypes       String?  // JSON array — task types willing to receive via relays: ["research","review","introductions","technical","creative","strategy","operations","mentoring"]
  
  // ── Availability ──
  timezone        String?  // e.g. "America/New_York"
  workingHours    String?  // JSON: {start:"09:00",end:"17:00",days:["mon","tue","wed","thu","fri"]}
  capacity        String   @default("available") // "available" | "busy" | "limited" | "unavailable"
  capacityNote    String?  // "Focused on product launch until March 15"
  outOfOffice     String?  // JSON: [{start,end,reason}]

  // ── Privacy ──
  visibility      String   @default("connections") // "public" | "connections" | "private"
  sharedSections  String?  // JSON array of section names shared with connections: ["professional","skills","availability"]

  // ── Job Preferences ──
  minCompensationType   String?   // "flat" | "hourly" | "weekly" | "monthly" — minimum type the user expects
  minCompensationAmount Float?    // Minimum dollar amount per unit
  minCompensationCurrency String  @default("USD") // ISO currency code
  acceptVolunteerWork   Boolean   @default(true)    // Willing to receive volunteer/unpaid job offers?
  acceptProjectInvites  Boolean   @default(true)    // Willing to receive project invites from connections?

  // ── Relay Preferences ──
  // Controls how the user participates in the ambient relay protocol
  relayMode           String   @default("full")     // "full" | "selective" | "minimal" | "off"
  allowAmbientInbound Boolean  @default(true)        // Can other agents send ambient relays to this user's Divi?
  allowAmbientOutbound Boolean @default(true)        // Can this user's Divi send ambient relays to others?
  allowBroadcasts     Boolean  @default(true)        // Can this user receive broadcast relays?
  autoRespondAmbient  Boolean  @default(false)       // Should Divi auto-respond to ambient relays without surfacing to user?
  relayQuietHours     String?  // JSON: {start:"22:00",end:"08:00",timezone:"America/Chicago"} — suppress non-urgent relays
  relayTopicFilters   String?  // JSON array of topics to opt out of: ["sales","recruiting"]
  briefVisibility     String   @default("self")      // "self" | "connections" | "public" — who can see reasoning briefs
  showBriefOnRelay    Boolean  @default(true)        // Attach assembled brief to outbound relays so recipients can inspect reasoning

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

// ─── Invitations ──────────────────────────────────────────────────────────────
// Outbound invites sent by users to bring new people onto DiviDen (or connect cross-instance).

model Invitation {
  id              String    @id @default(cuid())
  token           String    @unique @default(cuid()) // Deep-link token
  inviterId       String
  inviterName     String?   // Cached for email display
  inviterEmail    String?   // Cached for email display
  inviteeEmail    String    // Who we're inviting
  inviteeName     String?   // Optional display name
  message         String?   // Personal note from inviter
  status          String    @default("pending") // "pending" | "accepted" | "expired" | "cancelled"
  instanceUrl     String?   // If inviting TO a specific instance (for federation)
  sourceInstance  String?   // The instance URL this invite originated from (for cross-instance)
  acceptedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inviter         User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([inviterId])
  @@index([inviteeEmail])
  @@index([status])
  @@map("invitations")
}

// ─── Project Invites ────────────────────────────────────────────────────────
// Invitations to join a project or a job-created project.
// For connected users/team members — no recruiting fee (unlike job hiring).

model ProjectInvite {
  id            String    @id @default(cuid())
  projectId     String
  inviterId     String    // Who sent the invite
  inviteeId     String?   // DiviDen user (null if inviting by email/connection)
  inviteeEmail  String?   // Email for lookup / notification
  connectionId  String?   // If inviting a federated connection
  role          String    @default("contributor") // "lead" | "contributor" | "reviewer" | "observer"
  status        String    @default("pending")     // "pending" | "accepted" | "declined" | "expired"
  message       String?   // Personal note from inviter
  jobId         String?   // If this invite originated from a job hire

  // Agent intake tracking
  diviIntakeComplete Boolean @default(false) // Has Divi done intake with the invitee?
  intakeNotes        String? @db.Text        // Divi's intake summary / task breakdown

  acceptedAt    DateTime?
  declinedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter       User      @relation("ProjectInvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee       User?     @relation("ProjectInvitesReceived", fields: [inviteeId], references: [id], onDelete: Cascade)
  connection    Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  job           NetworkJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([projectId, inviteeId])
  @@index([projectId])
  @@index([inviterId])
  @@index([inviteeId])
  @@index([status])
  @@index([jobId])
  @@map("project_invites")
}

// ─── Federation Settings ──────────────────────────────────────────────────────
// Instance-level configuration for federation behavior.

model FederationConfig {
  id              String   @id @default(cuid())
  instanceName    String   @default("DiviDen") // This instance's display name
  instanceUrl     String?  // This instance's public URL
  federationMode  String   @default("closed") // "open" | "closed" | "allowlist"
  allowInbound    Boolean  @default(false)  // Accept incoming connection requests
  allowOutbound   Boolean  @default(true)   // Allow users to connect to external instances
  requireApproval Boolean  @default(true)   // Admin must approve new federated connections
  instanceApiKey  String?  // This instance's API key for outbound authentication
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("federation_config")
}

// ─── Teams ──────────────────────────────────────────────────────────────────
// Persistent groups of users who work together across multiple projects.
// Teams provide shared queue visibility, scoped broadcasts, and role-based trust.

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  avatar      String?      // Emoji or URL
  isActive    Boolean      @default(true)
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // ── Network Entity Fields ──
  type        String       @default("work")     // "work" | "community" | "hybrid"
  visibility  String       @default("private")   // "private" | "network" | "public"
  headline    String?      // One-liner like user profiles
  website     String?
  location    String?
  industry    String?
  foundedAt   DateTime?

  // ── Team Agent ──
  agentEnabled Boolean     @default(false)       // Requires Team Pro subscription
  agentConfig  String?     // JSON: system prompt overrides, check-in frequency, notification prefs

  createdBy   User         @relation("TeamsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  members     TeamMember[]
  projects    Project[]
  queueItems  QueueItem[]
  relays      AgentRelay[]
  goals       Goal[]
  subscription  TeamSubscription?
  billing       TeamBilling?
  spendingPolicies TeamSpendingPolicy[]
  agentAccess   TeamAgentAccess[]
  followers     TeamFollow[]

  @@index([createdById])
  @@index([type])
  @@index([visibility])
  @@map("teams")
}

model TeamMember {
  id           String      @id @default(cuid())
  teamId       String
  userId       String?     // Null if federated member (connected via connectionId)
  connectionId String?     // For federated members — the connection linking them
  role         String      @default("member") // "owner" | "admin" | "member"
  joinedAt     DateTime    @default(now())

  team         Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

// ─── Projects ────────────────────────────────────────────────────────────────
// Scoped, goal-based collaborations. Can belong to a team or be independent.
// Projects have shared queues, kanban lanes, and relay context.
// When a project ends, the grouping dissolves but connections persist.

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      String          @default("active") // "active" | "paused" | "completed" | "archived"
  visibility  String          @default("private") // "private" | "team" | "open"
  teamId      String?         // Optional team ownership
  createdById String
  color       String?         // Accent color for UI
  metadata    String?         // JSON for flexible data
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy   User            @relation("ProjectsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  team        Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  members     ProjectMember[]
  kanbanCards KanbanCard[]
  queueItems  QueueItem[]
  relays      AgentRelay[]
  goals       Goal[]
  networkJobs NetworkJob[]    // Reverse: job(s) linked to this project (typically 0 or 1)
  projectInvites ProjectInvite[]

  @@index([teamId])
  @@index([createdById])
  @@index([status])
  @@index([visibility])
  @@map("projects")
}

model ProjectMember {
  id           String      @id @default(cuid())
  projectId    String
  userId       String?     // Null if federated member
  connectionId String?     // For federated members — the connection linking them
  role         String      @default("contributor") // "lead" | "contributor" | "reviewer" | "observer"
  joinedAt     DateTime    @default(now())

  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

// ─── Agent Extensions ──────────────────────────────────────────────────────
// Installable skills, personas, and prompt layers via manual import or custom config.
// Extensions augment Divi's capabilities at user, team, or project scope.

// ─── Goals & Objectives ─────────────────────────────────────────────────────

model Goal {
  id          String    @id @default(cuid())
  title       String
  description String?
  timeframe   String    @default("quarter")   // "week" | "month" | "quarter" | "year"
  deadline    DateTime?
  impact      String    @default("medium")     // "low" | "medium" | "high" | "critical"
  status      String    @default("active")     // "active" | "paused" | "completed" | "abandoned"
  progress    Int       @default(0)            // 0-100 percentage
  metadata    String?                          // JSON: extra context, key results, etc.

  // Hierarchy — goals can ladder up
  parentGoalId String?
  parentGoal   Goal?   @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  subGoals     Goal[]  @relation("GoalHierarchy")

  // Scope — link to project / team (optional)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  teamId       String?
  team         Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Ownership
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([teamId])
  @@index([parentGoalId])
  @@map("goals")
}

// ─── Agent Extensions ───────────────────────────────────────────────────────

model AgentExtension {
  id            String   @id @default(cuid())
  name          String                          // Human-readable name
  slug          String                          // URL-safe identifier
  description   String?                         // What this extension does
  type          String   @default("skill")      // "skill" | "persona" | "prompt_layer"
  source        String   @default("manual")     // "manual" | "custom"
  sourceUrl     String?                         // Link to origin or documentation
  version       String   @default("1.0.0")

  // The extension configuration — prompt text, action tags, parameters, etc.
  config        String   @db.Text               // JSON: { promptText?, actionTags?, parameters?, model? }

  // Scope: where this extension is active
  scope         String   @default("user")       // "user" | "team" | "project" | "global"
  scopeId       String?                         // teamId or projectId (null for user/global scope)

  // Ownership
  installedById String
  installedBy   User     @relation(fields: [installedById], references: [id], onDelete: Cascade)

  isActive      Boolean  @default(true)
  priority      Int      @default(0)            // Higher = loaded earlier in prompt stack
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([installedById])
  @@index([scope, scopeId])
  @@index([isActive])
  @@map("agent_extensions")
}

// ─── DEP-013: Network Job Board ─────────────────────────────────────────────

model NetworkJob {
  id              String    @id @default(cuid())
  title           String
  description     String    @db.Text
  requirements    String?   @db.Text   // JSON array: skills/experience needed
  taskType        String    @default("custom") // matches UserProfile.taskTypes values
  urgency         String    @default("medium") // "low" | "medium" | "high" | "critical"
  status          String    @default("open")   // "open" | "in_progress" | "completed" | "cancelled" | "expired"
  compensation    String?   // freeform (legacy): "equity swap", "$500", "mutual exchange", "volunteer"
  estimatedHours  Float?    // estimated time commitment
  deadline        DateTime? // when the task needs to be done by
  
  // ─── Structured Compensation ──────────────────────────────────────
  compensationType   String?  // "flat" | "hourly" | "weekly" | "monthly" | "volunteer" | null (freeform/legacy)
  compensationAmount Float?   // Dollar amount per unit (flat total, or per hour/week/month)
  compensationCurrency String @default("USD") // ISO currency code
  isPaid             Boolean  @default(false) // true if compensationType is flat/hourly/weekly/monthly with amount > 0
  
  // Poster info
  posterId        String
  poster          User      @relation("JobsPosted", fields: [posterId], references: [id], onDelete: Cascade)
  
  // Assignment
  assigneeId      String?
  assignee        User?     @relation("JobsAssigned", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  // Matching metadata
  requiredSkills  String?   @db.Text  // JSON array: ["python", "negotiation"]
  preferredSkills String?   @db.Text  // JSON array: nice-to-haves
  
  // Visibility
  visibility      String    @default("network") // "network" (all instances) | "instance" (local only) | "connections" (poster's connections)
  
  // Results
  completionNote  String?   @db.Text
  
  // Project link — when a hire happens, a Project is created from this job
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  applications    JobApplication[]
  contracts       JobContract[]
  projectInvites  ProjectInvite[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  expiresAt       DateTime? // auto-expire

  @@index([posterId])
  @@index([assigneeId])
  @@index([status])
  @@index([taskType])
  @@index([urgency])
  @@index([createdAt])
  @@index([isPaid])
  @@index([projectId])
  @@map("network_jobs")
}

// ─── Job Contracts & Recruiting Payments ────────────────────────────────────

model JobContract {
  id              String    @id @default(cuid())
  jobId           String
  job             NetworkJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  // Parties
  clientId        String    // the person who posted the job (paying)
  client          User      @relation("JobContractsAsClient", fields: [clientId], references: [id], onDelete: Cascade)
  workerId        String    // the person hired
  worker          User      @relation("JobContractsAsWorker", fields: [workerId], references: [id], onDelete: Cascade)
  
  // Contract terms
  compensationType   String    // "flat" | "hourly" | "weekly" | "monthly"
  compensationAmount Float     // Dollar amount per unit
  currency           String    @default("USD")
  
  // Status tracking
  status          String    @default("active") // "active" | "paused" | "completed" | "cancelled" | "disputed"
  startDate       DateTime  @default(now())
  endDate         DateTime? // When contract ended
  
  // Recruiting fee (7% default, configurable via RECRUITING_FEE_PERCENT)
  recruitingFeePercent Float  @default(7)
  
  // Payment tracking
  totalPaid          Float    @default(0)  // Total paid to worker so far
  totalRecruitingFee Float    @default(0)  // Total recruiting fees collected
  
  // Stripe payment tracking
  stripePaymentIntentId String?  // For flat-fee: single payment intent
  stripePaymentStatus   String?  // "pending" | "succeeded" | "failed"
  
  // For recurring: track billing cycles
  lastPaymentAt    DateTime?
  nextPaymentDue   DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  payments        JobPayment[]

  @@index([jobId])
  @@index([clientId])
  @@index([workerId])
  @@index([status])
  @@map("job_contracts")
}

model JobPayment {
  id              String    @id @default(cuid())
  contractId      String
  contract        JobContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  // Payment details
  amount          Float     // Gross amount
  recruitingFee   Float     // Platform recruiting fee
  workerPayout    Float     // Amount to worker (amount - recruitingFee)
  feePercent      Float     // Fee % at time of payment
  
  // Billing period (for recurring)
  periodStart     DateTime?
  periodEnd       DateTime?
  description     String?   // "Week of Apr 7-13" or "April 2026" or "Flat fee"
  
  // Stripe
  stripePaymentIntentId String?
  stripePaymentStatus   String  @default("pending") // "pending" | "succeeded" | "failed" | "refunded"
  
  createdAt       DateTime  @default(now())

  @@index([contractId])
  @@index([stripePaymentStatus])
  @@map("job_payments")
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  job         NetworkJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User     @relation("JobApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // "pending" | "accepted" | "rejected" | "withdrawn"
  coverNote   String?  @db.Text  // why this person is a fit
  matchScore  Float?   // 0-1 computed match score
  matchReason String?  @db.Text  // why the match engine suggested this
  source      String   @default("manual") // "manual" | "agent_match" | "self_apply"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
  @@index([status])
  @@map("job_applications")
}

model ReputationScore {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("ReputationScores", fields: [userId], references: [id], onDelete: Cascade)
  
  // Score components
  jobsCompleted    Int      @default(0)
  jobsPosted       Int      @default(0)
  avgRating        Float    @default(0)  // 0-5 star average
  totalRatings     Int      @default(0)
  onTimeRate       Float    @default(1)  // 0-1 percentage of on-time completions
  responseRate     Float    @default(1)  // 0-1 percentage of applications responded to
  
  // Composite
  score            Float    @default(0)  // 0-100 computed reputation score
  level            String   @default("new") // "new" | "rising" | "established" | "trusted" | "exemplary"
  
  // Federation (FVP Brief Proposal #7: Portable Reputation)
  isFederated      Boolean  @default(false) // Has cross-instance endorsements
  endorsements     String?  // JSON array of signed attestation objects from remote instances
  federatedScore   Float    @default(0)     // Combined local + federated score
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId])
  @@index([score])
  @@index([level])
  @@map("reputation_scores")
}

model JobReview {
  id          String   @id @default(cuid())
  jobId       String
  reviewerId  String   // the person leaving the review
  revieweeId  String   // the person being reviewed
  rating      Float    // 1-5
  comment     String?  @db.Text
  type        String   // "poster_to_worker" | "worker_to_poster"
  
  createdAt   DateTime @default(now())

  @@unique([jobId, reviewerId])
  @@index([revieweeId])
  @@index([rating])
  @@map("job_reviews")
}

// ─── Telemetry ──────────────────────────────────────────────────────────────

model TelemetryEvent {
  id        String   @id @default(cuid())
  type      String   // "request" | "error" | "db_query"
  userId    String?  // user who triggered (null for unauthenticated)
  ip        String?  // client IP
  method    String?  // HTTP method: GET, POST, etc.
  path      String?  // request path
  statusCode Int?    // HTTP response status
  duration  Int?     // request duration in ms
  dbAction  String?  // "SELECT" | "INSERT" | "UPDATE" | "DELETE"
  dbModel   String?  // Prisma model name
  errorMessage String? @db.Text
  errorStack   String? @db.Text
  metadata  String?  @db.Text // JSON: extra context
  createdAt DateTime @default(now())

  @@index([type])
  @@index([userId])
  @@index([createdAt])
  @@index([path])
  @@map("telemetry_events")
}

// ─── Agent Marketplace ──────────────────────────────────────────────────────────

model MarketplaceAgent {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String    @db.Text
  longDescription String?   @db.Text  // rich markdown
  endpointUrl     String    // where the agent listens
  authMethod      String    @default("bearer") // "bearer" | "api_key" | "none" | "header"
  authHeader      String?   // custom header name if authMethod = "header"
  authToken       String?   // encrypted token / key for calling the agent

  // Developer info
  developerId     String
  developer       User      @relation("MarketplaceAgentsListed", fields: [developerId], references: [id], onDelete: Cascade)
  developerName   String    // display name
  developerUrl    String?   // website / github

  // Capabilities
  category        String    @default("general") // "research" | "coding" | "writing" | "analysis" | "operations" | "creative" | "general"
  tags            String?   @db.Text  // JSON array of tags
  inputFormat     String    @default("text") // "text" | "json" | "a2a"
  outputFormat    String    @default("text") // "text" | "json" | "a2a"
  samplePrompts   String?   @db.Text  // JSON array of example prompts

  // Pricing
  pricingModel    String    @default("free") // "free" | "per_task" | "subscription" | "tiered"
  pricePerTask    Float?    // $ per execution (if per_task)
  subscriptionPrice Float?  // $ per month (if subscription)
  taskLimit       Int?      // monthly task limit for subscription tier (null = unlimited)
  pricingDetails  String?   @db.Text  // JSON for complex tiered pricing

  // Revenue tracking
  totalGrossRevenue   Float   @default(0) // total gross $ earned
  totalPlatformFees   Float   @default(0) // total platform fee collected
  totalDeveloperPayout Float  @default(0) // total paid out to developer (gross - fees)
  pendingPayout       Float   @default(0) // accumulated but not yet withdrawn

  // Status & stats
  status          String    @default("pending") // "pending" | "active" | "disabled" | "suspended"
  featured        Boolean   @default(false)
  totalExecutions Int       @default(0)
  avgResponseTime Float?    // ms
  successRate     Float?    // 0-1
  avgRating       Float     @default(0)
  totalRatings    Int       @default(0)

  // Access password — developer can set a password that grants free access
  accessPassword  String?   // plain-text password; users who enter it get a free subscription

  // Protocol support
  supportsA2A     Boolean   @default(false)
  supportsMCP     Boolean   @default(false)
  agentCardUrl    String?   // URL to .well-known/agent-card.json

  // Versioning
  version             String    @default("1.0.0")  // semver
  changelog           String?   @db.Text  // JSON array of {version, date, changes} entries

  // Agent Integration Kit — knowledge transfer for consuming Divis
  taskTypes           String?   @db.Text  // JSON array: what this agent handles (e.g. ["research", "summarization", "code-review"])
  contextInstructions String?   @db.Text  // Markdown: how Divi should prepare context before calling this agent
  requiredInputSchema String?   @db.Text  // JSON schema: structured input the agent expects
  outputSchema        String?   @db.Text  // JSON schema: structured output the agent returns
  usageExamples       String?   @db.Text  // JSON array of {input, output, description} examples
  contextPreparation  String?   @db.Text  // JSON array of preparation steps Divi should follow
  executionNotes      String?   @db.Text  // Free-form notes about quirks, rate limits, best practices

  subscriptions   MarketplaceSubscription[]
  executions      MarketplaceExecution[]
  teamAccess      TeamAgentAccess[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([developerId])
  @@index([status])
  @@index([category])
  @@index([featured])
  @@index([pricingModel])
  @@index([createdAt])
  @@map("marketplace_agents")
}

model MarketplaceSubscription {
  id              String    @id @default(cuid())
  agentId         String
  agent           MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation("MarketplaceSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  status          String    @default("active") // "active" | "cancelled" | "expired" | "paused"
  tier            String    @default("standard") // "standard" | "pro" | "enterprise"
  tasksUsed       Int       @default(0)
  taskLimit       Int?      // null = unlimited
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime?
  cancelledAt     DateTime?

  // Agent Environment Management
  installed       Boolean   @default(false)  // true = agent is active in Divi's toolkit
  installedAt     DateTime?                  // when it was installed
  uninstalledAt   DateTime?                  // when it was last uninstalled
  pinnedVersion   String?                    // null = always latest; "1.2.0" = locked to specific version

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([agentId, userId])
  @@index([agentId])
  @@index([userId])
  @@index([status])
  @@index([installed])
  @@map("marketplace_subscriptions")
}

model MarketplaceExecution {
  id              String    @id @default(cuid())
  agentId         String
  agent           MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation("MarketplaceExecutions", fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId  String?   // if execution was against a subscription

  // Task details
  taskInput       String    @db.Text  // what the user sent
  taskOutput      String?   @db.Text  // what came back
  status          String    @default("pending") // "pending" | "running" | "completed" | "failed" | "timeout"
  errorMessage    String?   @db.Text

  // Performance
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  responseTimeMs  Int?
  
  // Revenue split
  grossAmount     Float     @default(0) // total charged for this execution
  platformFee     Float     @default(0) // DiviDen's routing fee
  developerPayout Float     @default(0) // developer's share (gross - fee)
  feePercent      Float     @default(3) // fee % applied at time of execution

  // Stripe payment
  stripePaymentIntentId String?  // Stripe PaymentIntent ID for this execution
  stripePaymentStatus   String?  // "succeeded" | "failed" | "pending" | "requires_action"

  // Feedback
  rating          Int?      // 1-5
  feedback        String?   @db.Text

  createdAt       DateTime  @default(now())

  @@index([agentId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([agentId, createdAt])  // Composite: agent execution history
  @@index([userId, createdAt])   // Composite: user execution history
  @@map("marketplace_executions")
}

// ─── Team Premium Features ───────────────────────────────────────────────────
// Teams are premium network entities with subscription billing, spending controls,
// agent sharing, and optional AI team coordination agent.

model TeamSubscription {
  id                    String    @id @default(cuid())
  teamId                String    @unique
  tier                  String    @default("starter") // "starter" | "pro"
  status                String    @default("trialing") // "active" | "past_due" | "canceled" | "trialing"
  memberLimit           Int       @default(5) // 5 for starter, 10 base for pro
  currentMembers        Int       @default(0)
  monthlyPrice          Float     @default(29) // $29 starter, $79 pro
  perSeatPrice          Float?    // null for starter, $9 for pro (beyond base)
  billingCycleStart     DateTime  @default(now())
  trialEndsAt           DateTime? // 14-day free trial
  canceledAt            DateTime?
  stripeSubscriptionId  String?   @unique
  stripeCustomerId      String?   // Team-level Stripe customer (separate from individual)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  team                  Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tier])
  @@map("team_subscriptions")
}

model TeamBilling {
  id                String    @id @default(cuid())
  teamId            String    @unique
  stripeCustomerId  String?   // Stripe customer for team-level charges
  monthlyBudget     Float?    // Monthly spending cap (null = unlimited)
  currentSpend      Float     @default(0)
  billingCycleStart DateTime  @default(now())
  isActive          Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  team              Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_billing")
}

model TeamSpendingPolicy {
  id            String    @id @default(cuid())
  teamId        String
  type          String    // "per_member" | "per_project" | "per_agent"
  targetId      String?   // memberId, projectId, or agentId depending on type
  limit         Float     // $ limit for this policy
  currentSpend  Float     @default(0)
  period        String    @default("monthly") // "monthly" | "weekly"
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([teamId, type])
  @@map("team_spending_policies")
}

model TeamAgentAccess {
  id          String    @id @default(cuid())
  teamId      String
  agentId     String    // MarketplaceAgent ID
  grantedById String    // User who shared the agent with the team
  isActive    Boolean   @default(true)
  usageLimit  Int?      // Optional: max executions per member per billing cycle

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent       MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  grantedBy   User             @relation("TeamAgentGrantedBy", fields: [grantedById], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
  @@index([teamId])
  @@index([agentId])
  @@map("team_agent_access")
}

model TeamFollow {
  id        String    @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@map("team_follows")
}