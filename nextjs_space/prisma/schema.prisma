// DiviDen Command Center - Database Schema
// Supports PostgreSQL

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/dividen_command_center/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Authentication & Users ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          String    @default("admin")
  mode          String    @default("cockpit") // "cockpit" | "chief_of_staff"
  hasSeenWalkthrough Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  kanbanCards   KanbanCard[]
  chatMessages  ChatMessage[]
  contacts      Contact[]
  memoryItems   MemoryItem[]
  userLearnings UserLearning[]
  externalApiKeys ExternalApiKey[]
  webhooks      Webhook[]
  serviceApiKeys ServiceApiKey[]
  documents     Document[]
  recordings      Recording[]
  commsMessages   CommsMessage[]
  calendarEvents  CalendarEvent[]
  emailMessages   EmailMessage[]
  integrationAccounts IntegrationAccount[]
  notificationRules   NotificationRule[]
  connectionsRequested Connection[] @relation("ConnectionsRequested")
  connectionsAccepted  Connection[] @relation("ConnectionsAccepted")
  relaysSent           AgentRelay[] @relation("RelaysSent")
  relaysReceived       AgentRelay[] @relation("RelaysReceived")
  profile              UserProfile?

  @@map("users")
}

// ─── Kanban Board ──────────────────────────────────────────────────────────────

model KanbanCard {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      String          @default("leads") // pipeline stage
  priority    String          @default("medium")   // "low" | "medium" | "high" | "urgent"
  assignee    String          @default("human") // "human" | "agent"
  dueDate     DateTime?
  order       Int             @default(0)
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist   ChecklistItem[]
  contacts    CardContact[]
  documents   Document[]
  recordings    Recording[]
  commsMessages CommsMessage[]
  emailMessages EmailMessage[]

  @@map("kanban_cards")
}

model ChecklistItem {
  id        String     @id @default(cuid())
  text      String
  completed Boolean    @default(false)
  order     Int        @default(0)
  cardId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ─── Queue System ──────────────────────────────────────────────────────────────

model QueueItem {
  id          String   @id @default(cuid())
  type        String   // "task" | "notification" | "reminder" | "agent_suggestion"
  title       String
  description String?
  priority    String   @default("medium")  // "low" | "medium" | "high" | "urgent"
  status      String   @default("ready")   // "ready" | "in_progress" | "done_today" | "blocked"
  source      String?  // "user" | "agent" | "system"
  userId      String?
  metadata    String?  // JSON string for flexible data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("queue_items")
}

// ─── Chat & Agent Communication ────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant" | "system"
  content   String
  userId    String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("chat_messages")
}

model AgentMessage {
  id        String   @id @default(cuid())
  agentName String
  type      String   // "status_update" | "suggestion" | "alert" | "completion"
  content   String
  priority  String   @default("normal")
  read      Boolean  @default(false)
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  @@map("agent_messages")
}

// ─── CRM / Contacts ───────────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  role         String?
  notes        String?
  tags         String?       // Comma-separated tags
  source       String?       // "manual" | "chat" | "enriched"
  enrichedData String?       // JSON string for enrichment data
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards             CardContact[]
  commsMessages     CommsMessage[]
  emailMessages     EmailMessage[]
  relationshipsFrom ContactRelationship[] @relation("RelFrom")
  relationshipsTo   ContactRelationship[] @relation("RelTo")

  @@map("contacts")
}

model ContactRelationship {
  id           String   @id @default(cuid())
  fromId       String
  toId         String
  type         String   // "colleague" | "manager" | "report" | "partner" | "spouse" | "friend" | "referral" | "custom"
  label        String?  // Optional freeform label (e.g. "introduced by")
  createdAt    DateTime @default(now())

  from         Contact  @relation("RelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to           Contact  @relation("RelTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
  @@map("contact_relationships")
}

model CardContact {
  id        String     @id @default(cuid())
  cardId    String
  contactId String
  role      String?    // Contact's role in this card
  createdAt DateTime   @default(now())

  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  contact   Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([cardId, contactId])
  @@map("card_contacts")
}

// ─── AI Memory & Learning ──────────────────────────────────────────────────────

model MemoryItem {
  id         String   @id @default(cuid())
  tier       Int      @default(1) // 1=Explicit Facts, 2=Behavioral Rules, 3=Learned Patterns
  category   String   // Tier1: "general"|"project"|"contact" | Tier2: "communication"|"workflow"|"preferences" | Tier3: "style"|"preference"|"workflow"|"communication"
  key        String
  value      String
  scope      String?  // Tier1: scope context (e.g., project name, contact name)
  pinned     Boolean  @default(false) // Tier1: pin for high priority
  priority   String?  // Tier2: "critical"|"high"|"medium"|"low"
  confidence Float?   // Tier3: confidence score 0.0-1.0
  approved   Boolean? // Tier3: user approval status (null=pending, true=approved, false=rejected)
  source     String?  // "user" | "agent" | "system"
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("memory_items")
}

model AgentRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  rule        String   // The actual rule text
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("agent_rules")
}

model UserLearning {
  id          String   @id @default(cuid())
  category    String   // "style" | "preference" | "workflow" | "communication"
  observation String
  confidence  Float    @default(0.5)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_learnings")
}

// ─── Configuration ─────────────────────────────────────────────────────────────

model AgentApiKey {
  id        String   @id @default(cuid())
  provider  String   // "openai" | "anthropic"
  label     String?
  apiKey    String   // Encrypted in production
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agent_api_keys")
}

// ─── Webhook Infrastructure ──────────────────────────────────────────────────

model Webhook {
  id          String       @id @default(cuid())
  name        String
  type        String       // "calendar" | "email" | "transcript" | "generic"
  url         String?      // Generated webhook URL path
  secret      String       // Secret for signature validation
  isActive    Boolean      @default(true)
  mappingRules String?     // JSON string for payload-to-action mapping rules
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        WebhookLog[]

  @@index([userId])
  @@index([secret])
  @@map("webhooks")
}

model WebhookLog {
  id          String   @id @default(cuid())
  webhookId   String
  payload     String   // JSON string of incoming payload
  status      String   // "success" | "error" | "ignored"
  statusCode  Int      @default(200)
  error       String?
  actionsRun  String?  // JSON string of actions executed
  createdAt   DateTime @default(now())

  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_logs")
}

model ServiceApiKey {
  id          String   @id @default(cuid())
  service     String   // "sendgrid" | "twilio" | "slack" | "custom" etc.
  keyName     String   // Display name / label
  keyValue    String   // Encrypted API key value
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("service_api_keys")
}

// ─── Documents / Drive ──────────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  title       String
  content     String?  // Markdown content
  type        String   @default("note") // "note" | "report" | "template" | "meeting_notes"
  tags        String?  // Comma-separated
  url         String?  // External file URL (Google Drive, Dropbox, etc.)
  fileSource  String   @default("local") // "local" | "google_drive" | "dropbox" | "onedrive" | "url"
  cardId      String?  // Optional link to a KanbanCard
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        KanbanCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  commsMessages CommsMessage[]

  @@index([userId])
  @@map("documents")
}

// ─── Recordings (Plaud, Otter, Fireflies, etc.) ────────────────────────────

model Recording {
  id          String   @id @default(cuid())
  title       String
  source      String   @default("generic") // "plaud" | "otter" | "fireflies" | "generic"
  transcript  String?  // Full transcript text
  summary     String?  // AI-generated summary
  duration    Int?     // Duration in seconds
  status      String   @default("pending") // "pending" | "processed" | "reviewed"
  metadata    String?  // JSON string for flexible data
  cardId      String?  // Optional link to a KanbanCard
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        KanbanCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  commsMessages CommsMessage[]

  @@index([userId])
  @@map("recordings")
}

// ─── Activity Log ───────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // "card_created" | "card_moved" | "task_dispatched" | "contact_added" | "mode_changed" | "recording_processed" etc.
  actor     String   @default("user") // "user" | "divi" | "system" | agent name
  summary   String   // Human-readable description
  metadata  String?  // JSON string with details
  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Calendar Events ─────────────────────────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  location    String?
  attendees   String?   // JSON array of attendees
  source      String    @default("webhook") // "webhook" | "manual" | "google"
  externalId  String?   // ID from external system
  metadata    String?   // JSON string
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
  @@map("calendar_events")
}

// ─── Email Messages ──────────────────────────────────────────────────────────

model EmailMessage {
  id              String     @id @default(cuid())
  subject         String
  fromName        String?
  fromEmail       String?
  toEmail         String?
  body            String?    // Full body or preview
  snippet         String?    // Short preview
  labels          String?    // Comma-separated: "inbox,important,starred"
  isRead          Boolean    @default(false)
  isStarred       Boolean    @default(false)
  source          String     @default("webhook") // "webhook" | "manual" | "gmail"
  externalId      String?    // ID from external system
  linkedCardId    String?
  linkedContactId String?
  metadata        String?    // JSON string
  userId          String
  receivedAt      DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedCard      KanbanCard? @relation(fields: [linkedCardId], references: [id], onDelete: SetNull)
  linkedContact   Contact?   @relation(fields: [linkedContactId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([receivedAt])
  @@index([isRead])
  @@map("email_messages")
}

// ─── Comms Channel ───────────────────────────────────────────────────────────

model CommsMessage {
  id              String     @id @default(cuid())
  sender          String     // "user" | "divi" | "system"
  content         String
  state           String     @default("new") // "new" | "read" | "acknowledged" | "resolved" | "dismissed"
  priority        String     @default("normal") // "urgent" | "normal" | "low"
  linkedCardId    String?
  linkedContactId String?
  linkedRecordingId String?
  linkedDocumentId String?
  metadata        String?    // JSON string for flexible data
  userId          String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedCard      KanbanCard? @relation(fields: [linkedCardId], references: [id], onDelete: SetNull)
  linkedContact   Contact?   @relation(fields: [linkedContactId], references: [id], onDelete: SetNull)
  linkedRecording Recording? @relation(fields: [linkedRecordingId], references: [id], onDelete: SetNull)
  linkedDocument  Document?  @relation(fields: [linkedDocumentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([state])
  @@index([createdAt])
  @@map("comms_messages")
}

// External Agent API Keys for v2 API authentication
model ExternalApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  keyPrefix   String
  permissions String    @default("all")
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
  @@map("external_api_keys")
}

// ─── Integration Accounts (Dual Identity) ──────────────────────────────────────
// Each user can have integration credentials for both their own identity
// ("operator") and their agent's identity ("agent"). This enables the agent
// to operate with its own email, calendar, and drive — separate from the user's.

model IntegrationAccount {
  id            String   @id @default(cuid())
  userId        String
  identity      String   // "operator" | "agent"
  provider      String   // "google" | "microsoft" | "smtp"
  service       String   // "email" | "calendar" | "drive"
  label         String?  // Display name, e.g. "Divi's Gmail" or "My Work Calendar"

  // OAuth fields
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?
  scope         String?

  // SMTP / App Password fields
  smtpHost      String?
  smtpPort      Int?
  smtpUser      String?
  smtpPass      String?  // encrypted at rest

  // Shared config
  emailAddress  String?  // The actual email address for this identity
  isActive      Boolean  @default(true)
  lastSyncAt    DateTime?
  syncCursor    String?  // Pagination cursor for incremental sync
  metadata      String?  // JSON - provider-specific config

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, identity, service])
  @@index([userId])
  @@map("integration_accounts")
}

// ─── Notification Rules ────────────────────────────────────────────────────────
// User-defined rules that trigger cockpit banners when conditions are met.

model NotificationRule {
  id          String   @id @default(cuid())
  userId      String
  name        String   // e.g. "Meeting Starting Soon"
  eventType   String   // "meeting_starting" | "task_overdue" | "email_received" | "contact_stale" | "card_moved" | "queue_added" | "custom"
  conditions  String?  // JSON — optional extra conditions (e.g. {"minutesBefore": 5})
  message     String   // Template string, e.g. "Meeting '{{title}}' starts in {{minutes}}m"
  style       String   @default("info") // "info" | "warning" | "urgent" | "success"
  sound       Boolean  @default(false)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_rules")
}

// ─── Connections ──────────────────────────────────────────────────────────────
// Links between two users, enabling agent-to-agent communication.
// Connections can be local (same instance) or federated (cross-instance).

model Connection {
  id              String   @id @default(cuid())
  requesterId     String   // User who initiated the connection
  accepterId      String?  // User who accepted (null if federated pending)
  status          String   @default("pending") // "pending" | "active" | "blocked" | "declined"

  // Permission scopes — what the other party's agent can do
  permissions     String   @default("{\"trustLevel\":\"supervised\",\"scopes\":[]}") // JSON: { trustLevel, scopes[] }

  // Display
  nickname        String?  // How the requester refers to the other party
  peerNickname    String?  // How the accepter refers to the requester

  // Federation fields (cross-instance connections)
  isFederated     Boolean  @default(false)
  peerInstanceUrl String?  // The remote instance's base URL
  peerUserId      String?  // The user ID on the remote instance
  peerUserName    String?  // Display name of the remote user
  peerUserEmail   String?  // Email of the remote user
  federationToken String?  // Shared secret for authenticating relay messages

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester       User     @relation("ConnectionsRequested", fields: [requesterId], references: [id], onDelete: Cascade)
  accepter        User?    @relation("ConnectionsAccepted", fields: [accepterId], references: [id], onDelete: Cascade)
  relays          AgentRelay[]

  @@unique([requesterId, accepterId])
  @@index([requesterId])
  @@index([accepterId])
  @@index([status])
  @@map("connections")
}

// ─── Agent Relay ──────────────────────────────────────────────────────────────
// Structured request/response protocol between connected agents.
// This is the core communication primitive — Divi-to-Divi messaging.

model AgentRelay {
  id              String    @id @default(cuid())
  connectionId    String
  fromUserId      String    // Sender (local user ID)
  toUserId        String?   // Receiver (local user ID, null if federated)
  direction       String    @default("outbound") // "outbound" | "inbound"

  // Message classification
  type            String    // "request" | "response" | "notification" | "update"
  intent          String    // "get_info" | "assign_task" | "request_approval" | "share_update" | "schedule" | "introduce" | "custom"
  subject         String
  payload         String?   // JSON — structured data for the relay
  
  // Lifecycle
  status          String    @default("pending") // "pending" | "delivered" | "agent_handling" | "user_review" | "completed" | "declined" | "expired"
  priority        String    @default("normal") // "urgent" | "normal" | "low"
  dueDate         DateTime?
  resolvedAt      DateTime?
  responsePayload String?   // JSON — the response data

  // Threading
  parentRelayId   String?
  parentRelay     AgentRelay?  @relation("RelayThread", fields: [parentRelayId], references: [id], onDelete: SetNull)
  childRelays     AgentRelay[] @relation("RelayThread")

  // Federation
  peerRelayId     String?   // The relay ID on the remote instance
  peerInstanceUrl String?   // Remote instance URL (for federated relays)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  connection      Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  fromUser        User       @relation("RelaysSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User?      @relation("RelaysReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@index([createdAt])
  @@map("agent_relays")
}

// ─── Instance Registry ────────────────────────────────────────────────────────
// Tracks known DiviDen instances for federation.
// Each instance has a shared API key for authenticating relay messages.

model InstanceRegistry {
  id              String   @id @default(cuid())
  name            String   // Display name, e.g. "Acme Corp DiviDen"
  baseUrl         String   @unique // The instance's public URL
  apiKey          String   // Shared secret for authenticating inbound relays
  isActive        Boolean  @default(true)
  isTrusted       Boolean  @default(false) // Admin-approved trust
  lastSeenAt      DateTime?
  metadata        String?  // JSON — capabilities, version, etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([baseUrl])
  @@map("instance_registry")
}

// ─── User Profile ─────────────────────────────────────────────────────────────
// Extended identity — professional + lived experience + availability.
// Shared with connections so agents can assess fitness for tasks.

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  
  // ── Professional ──
  headline        String?  // "Founder & CEO at Acme" — one-liner
  bio             String?  // Longer narrative bio
  currentTitle    String?
  currentCompany  String?
  industry        String?
  skills          String?  // JSON array: ["negotiation","python","design"]
  experience      String?  // JSON array: [{title,company,startYear,endYear,description}]
  education       String?  // JSON array: [{school,degree,field,year}]
  linkedinUrl     String?
  linkedinData    String?  // JSON — raw imported LinkedIn data

  // ── Lived Experience ──
  languages       String?  // JSON array: [{language,proficiency}] — "native","fluent","conversational","basic"
  countriesLived  String?  // JSON array: [{country,years,context}]
  lifeExperiences String?  // JSON array: [{category,description,year?}] — freeform life milestones
  volunteering    String?  // JSON array: [{org,role,description}]
  hobbies         String?  // JSON array: ["photography","hiking","chess"]
  personalValues  String?  // JSON array: ["integrity","creativity","empathy"]
  superpowers     String?  // JSON array — self-identified strengths beyond skills: ["crisis management","cross-cultural communication"]
  
  // ── Availability ──
  timezone        String?  // e.g. "America/New_York"
  workingHours    String?  // JSON: {start:"09:00",end:"17:00",days:["mon","tue","wed","thu","fri"]}
  capacity        String   @default("available") // "available" | "busy" | "limited" | "unavailable"
  capacityNote    String?  // "Focused on product launch until March 15"
  outOfOffice     String?  // JSON: [{start,end,reason}]

  // ── Privacy ──
  visibility      String   @default("connections") // "public" | "connections" | "private"
  sharedSections  String?  // JSON array of section names shared with connections: ["professional","skills","availability"]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

// ─── Federation Settings ──────────────────────────────────────────────────────
// Instance-level configuration for federation behavior.

model FederationConfig {
  id              String   @id @default(cuid())
  instanceName    String   @default("DiviDen") // This instance's display name
  instanceUrl     String?  // This instance's public URL
  federationMode  String   @default("closed") // "open" | "closed" | "allowlist"
  allowInbound    Boolean  @default(false)  // Accept incoming connection requests
  allowOutbound   Boolean  @default(true)   // Allow users to connect to external instances
  requireApproval Boolean  @default(true)   // Admin must approve new federated connections
  instanceApiKey  String?  // This instance's API key for outbound authentication
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("federation_config")
}